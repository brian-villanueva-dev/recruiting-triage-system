# Anthropic API Key — get one at https://console.anthropic.com
# Paste directly into the n8n HTTP Request node header, not here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google OAuth — configured inside n8n's credential manager
# No environment variables needed; n8n handles the OAuth flow

# n8n Form URL (set automatically when workflow is published)
# Production URL will look like: http://localhost:5678/form/...
